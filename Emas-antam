<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AntamCuan - Investasi Emas</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #ffffff;
      color: #333;
    }
    header {
      background: linear-gradient(to right, #d4af37, #ffffff);
      padding: 30px;
      text-align: center;
      color: #333;
    }
    header h1 {
      margin: 0;
      font-size: 2.5em;
    }
    header p {
      font-size: 1.2em;
    }
    nav {
      display: flex;
      justify-content: flex-end;
      padding: 10px 30px;
      background-color: #f9f9f9;
    }
    nav a {
      margin-left: 15px;
      text-decoration: none;
      font-weight: bold;
      background-color: #d4af37;
      padding: 8px 15px;
      border-radius: 6px;
      color: white;
    }
    .produk {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      padding: 40px;
      background-color: #f9f9f9;
    }
    .card {
      background-color: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 10px;
      padding: 20px;
      text-align: center;
      box-shadow: 0 4px 8px rgba(0,0,0,0.05);
    }
    .card img {
      width: 80px;
      margin-bottom: 15px;
    }
    .card h3 {
      margin: 10px 0;
      color: #d4af37;
    }
    .card p {
      font-size: 0.9em;
    }
    footer {
      background-color: #f2f2f2;
      text-align: center;
      padding: 20px;
    }
    .wa {
      display: inline-block;
      margin-top: 10px;
      padding: 10px 20px;
      background-color: #25D366;
      color: white;
      border-radius: 8px;
      text-decoration: none;
      font-weight: bold;
    }
    .auth-section {
      padding: 40px;
      background-color: #ffffff;
      text-align: center;
    }
    .auth-section form {
      max-width: 400px;
      margin: 20px auto;
      background: #f9f9f9;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
    }
    .auth-section input[type="text"], .auth-section input[type="password"] {
      width: 100%;
      padding: 10px;
      margin: 10px 0;
      border-radius: 6px;
      border: 1px solid #ccc;
    }
    .auth-section button {
      background-color: #d4af37;
      color: white;
      padding: 10px 20px;
      border: none;
      border-radius: 6px;
      font-weight: bold;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <nav>
    <a href="#login">Login</a>
    <a href="#register">Daftar</a>
  </nav>

  <header>
    <h1>AntamCuan</h1>
    <p>Solusi Investasi Emas Terpercaya</p>
  </header>

  <section class="produk">
    <div class="card">
      <img src="https://upload.wikimedia.org/wikipedia/commons/3/30/Gold_bar_icon.png" alt="Emas 1 gram">
      <h3>Emas Antam 1 Gram</h3>
      <p>Harga: Rp1.150.000</p>
    </div>
    <div class="card">
      <img src="https://upload.wikimedia.org/wikipedia/commons/3/30/Gold_bar_icon.png" alt="Emas 5 gram">
      <h3>Emas Antam 5 Gram</h3>
      <p>Harga: Rp5.500.000</p>
    </div>
    <div class="card">
      <img src="https://upload.wikimedia.org/wikipedia/commons/3/30/Gold_bar_icon.png" alt="Emas 10 gram">
      <h3>Emas Antam 10 Gram</h3>
      <p>Harga: Rp10.900.000</p>
    </div>
  </section>

  <section class="auth-section" id="login">
    <h2>Login</h2>
    <form>
      <input type="text" placeholder="Email atau Username" required />
      <input type="password" placeholder="Password" required />
      <button type="submit">Login</button>
    </form>
  </section>

  <section class="auth-section" id="register">
    <h2>Daftar Akun Baru</h2>
    <form>
      <input type="text" placeholder="Nama Lengkap" required />
      <input type="text" placeholder="Email" required />
      <input type="password" placeholder="Password" required />
      <button type="submit">Daftar</button>
    </form>
  </section>

  <footer>
    <p>Hubungi kami untuk pemesanan dan konsultasi investasi</p>
    <a href="https://wa.me/6281234567890" class="wa">Chat WhatsApp</a>
  </footer>
</body>
</html>
